# ============================================================
#  HandwerkerPro REST-API — Umgebungsvariablen
#
#  ANLEITUNG:
#    1. Diese Datei als ".env" kopieren
#    2. Alle Werte anpassen
#    3. .env niemals in Git committen! (.gitignore beachten)
# ============================================================

# ── Anwendung ────────────────────────────────────────────────
APP_ENV=development       # development | production
APP_DEBUG=true            # true nur in Entwicklung!

# ── Datenbank ────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=handwerkerpro_db
DB_USER=root
DB_PASS=

# ── API-Keys ─────────────────────────────────────────────────
# Starke, zufällige Keys verwenden! Beispiel generieren:
#   php -r "echo bin2hex(random_bytes(32));"
#
# Entwicklung (Beispielwerte — in Produktion unbedingt ersetzen!):
API_KEY_ADMIN=admin-key-12345
API_KEY_MEISTER=meister-key-67890
API_KEY_GESELLE=geselle-key-11111

# ── CORS ─────────────────────────────────────────────────────
# Entwicklung:          CORS_ORIGINS=*
# Sprint 7 (Frontend):  CORS_ORIGINS=http://localhost:3000
# Produktion:           CORS_ORIGINS=https://mein-frontend.de
# Mehrere Origins:      CORS_ORIGINS=https://a.de,https://b.de
CORS_ORIGINS=*

# ── Demo-Passwort ────────────────────────────────────────────
# Nur aktiv wenn APP_ENV=development — niemals in Produktion!
DEMO_PASSWORD=demo123
